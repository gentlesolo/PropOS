{
  "name": "ProposMobile",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "ios:beta": "bundle exec fastlane ios beta",
    "android:beta": "bundle exec fastlane android beta"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.76.5",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/stack": "^6.4.1",
    "@react-navigation/native-stack": "^6.11.0",
    "react-native-screens": "^3.34.0",
    "react-native-safe-area-context": "^4.11.0",
    "@tanstack/react-query": "^5.56.2",
    "axios": "^1.7.7",
    "zustand": "^5.0.0",
    "react-native-mmkv": "^3.1.0",
    "react-native-keychain": "^8.2.0",
    "react-native-biometrics": "^3.0.1",
    "@twilio/voice-react-native-sdk": "^1.1.0",
    "@notifee/react-native": "^9.1.8",
    "@react-native-firebase/app": "^21.1.1",
    "@react-native-firebase/messaging": "^21.1.1",
    "react-native-callkeep": "^4.3.13",
    "react-native-push-notification-ios": "^1.11.0",
    "nativewind": "^4.0.1",
    "react-native-vector-icons": "^10.2.0",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "react-native-audio-recorder-player": "^3.6.10",
    "date-fns": "^4.1.0",
    "pusher-js": "^8.4.0",
    "i18next": "^23.15.1",
    "react-i18next": "^15.0.2",
    "react-native-localize": "^3.2.2",
    "@sentry/react-native": "^5.32.0",
    "react-native-watch-connectivity": "^1.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native/babel-preset": "0.76.5",
    "@react-native/eslint-config": "0.76.5",
    "@react-native/metro-config": "0.76.5",
    "@react-native/typescript-config": "0.76.5",
    "@types/react": "^18.3.11",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/i18next": "^13.0.0",
    "tailwindcss": "^3.4.13",
    "typescript": "5.0.4",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.7.2",
    "eslint": "^8.57.1"
  },
  "jest": {
    "preset": "react-native",
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|nativewind|react-native-mmkv|react-native-keychain|react-native-biometrics|react-native-localize|pusher-js)/)"
    ]
  }
}
